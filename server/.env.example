# Bu dosyayi kopyalayip ".env" olarak adlandirin ve gercek degerlerle doldurun.
# .env dosyasi .gitignore ile haric tutulur; ASLA commit etmeyin.

# JWT imzalama anahtari (KRITIK). Guclu, rastgele bir deger uretin.
# Ornek (yerelde): python -c "import secrets; print(secrets.token_urlsafe(64))"
# Tanimli degilse uygulama BASLAMAZ.
JWT_SECRET_KEY=YOUR_JWT_SECRET_KEY_HERE

# MongoDB baglanti adresi.
MONGO_URI=mongodb://localhost:27017/***REMOVED***

# CORS icin izin verilen origin'ler (virgulle ayrilmis).
# Ornek: https://app.example.com,https://www.example.com
CORS_ORIGINS=http://localhost:3000

# Flask debug modu. Uretimde KESINLIKLE "false" birakin.
FLASK_DEBUG=false
